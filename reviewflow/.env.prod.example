# Copy to .env.prod and fill in real values. NEVER commit .env.prod.
# Bring the stack up with:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Public ------------------------------------------------------------------
# The domain Caddy serves on (must already point to this host's IP).
DOMAIN=reviewflow.example.com
# Email used for Let's Encrypt account recovery.
ACME_EMAIL=you@example.com

# --- MongoDB (auth enabled) --------------------------------------------------
MONGO_ROOT_USERNAME=reviewflow
# Generate something strong, e.g. `openssl rand -hex 24`
MONGO_ROOT_PASSWORD=replace-with-a-strong-secret

# --- Backend -----------------------------------------------------------------
# Use the credentials above. authSource=admin because the root user is created
# in the admin database by MONGO_INITDB_ROOT_*.
MONGO_URI=mongodb://reviewflow:replace-with-a-strong-secret@mongo:27017/?authSource=admin
MONGO_DB=reviewflow
PORT=8080
ENVIRONMENT=production

# --- Sessions ----------------------------------------------------------------
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32

# --- GitHub OAuth ------------------------------------------------------------
# Register an OAuth App at https://github.com/settings/developers
#   Homepage URL:               https://reviewflow.example.com
#   Authorization callback URL: https://reviewflow.example.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://reviewflow.example.com/auth/github/callback

# --- URLs --------------------------------------------------------------------
# Frontend and backend share an origin behind Caddy in prod, so these are the
# same: https://<DOMAIN>.
CORS_ORIGIN=https://reviewflow.example.com
FRONTEND_URL=https://reviewflow.example.com

# --- AI (Google Gemini, free tier) -------------------------------------------
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
