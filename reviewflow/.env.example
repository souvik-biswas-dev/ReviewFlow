# Copy to .env and adjust as needed:  cp .env.example .env
#
# Docker Compose loads this file into the app container's environment
# (env_file), where the Go app reads each value via os.Getenv.

# --- HTTP ---
PORT=8080
ENVIRONMENT=development

# --- CORS ---
# Origin of the SvelteKit dev server that calls this API from the browser.
CORS_ORIGIN=http://localhost:5173

# --- MongoDB ---
# Inside the Compose network, MongoDB is reachable by its service name "mongo".
# If you run the Go binary directly on your host instead, use:
#   MONGO_URI=mongodb://localhost:27017
MONGO_URI=mongodb://mongo:27017
MONGO_DB=reviewflow

# --- Auth / JWT ---
# Generate a strong secret, e.g.:  openssl rand -hex 32
JWT_SECRET=dev-insecure-secret-change-me

# --- GitHub OAuth ---
# Register an OAuth App at https://github.com/settings/developers
#   - Homepage URL:               http://localhost:5173
#   - Authorization callback URL: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback

# Where the browser is sent after a successful login.
FRONTEND_URL=http://localhost:5173

# --- AI (Google Gemini, free tier) ---
# Get a free key at https://aistudio.google.com/apikey
# Leave empty to disable AI reviews (the app still runs; aiReview stays null).
GEMINI_API_KEY=
